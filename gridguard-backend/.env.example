# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GridGuard AI — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Database
DATABASE_URL=postgresql+asyncpg://gridguard:gridguard_secret@localhost:5432/gridguard_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_EXPIRE_DAYS=90

# Razorpay (UPI Sandbox)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# OpenWeather API
OPENWEATHER_API_KEY=your_openweather_api_key

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# CPCB AQI API
CPCB_API_KEY=your_cpcb_api_key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Firebase Cloud Messaging
FIREBASE_SERVER_KEY=your_firebase_server_key

# TorchServe
TORCHSERVE_URL=http://localhost:8080

# Internal API Key (for service-to-service calls)
INTERNAL_API_KEY=your-internal-api-key-change-in-production

# Sentry (Error Monitoring)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Environment
ENVIRONMENT=development
