# Core services
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=gridguard
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-this-secret-key-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
INTERNAL_API_KEY=dev-internal-key
INTERNAL_API_BASE_URL=http://backend:8000
ADMIN_EMAILS=vedaantsinngh@gmail.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Payout provider (mock | razorpay)
PAYOUT_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_FALLBACK_TO_MOCK=true

# ML
MODEL_PATH=models/risk_model.pkl
MODEL_VERSION=1.0.0

# Optional integrations
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=GridGuard AI <noreply@gridguard.ai>
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# Data source mode: real | demo
GRID_DATA_MODE=real

# AQI providers
# Primary: WAQI
# Fallback: Open-Meteo Air Quality (no key needed)
WAQI_API_TOKEN=

# Traffic providers
# Primary: OpenRouteService
# Fallback: TomTom Traffic
ORS_API_KEY=
TOMTOM_API_KEY=

# Weather providers
# Primary: Open-Meteo (no key needed)
# Fallback: OpenWeather
OPENWEATHER_API_KEY=

SENTRY_DSN=
ENVIRONMENT=docker
STALE_EVENT_MINUTES=90
